generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  games         Game[]
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Game {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  twitchGameId  String?
  steamAppId    String?
  imageUrl      String?
  trackSessions TrackSession[]
  createdAt     DateTime       @default(now())
}

model TrackSession {
  id            String        @id @default(cuid())
  gameId        String
  game          Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  twitchChannel String
  status        String        @default("ACTIVE")
  allChat       Boolean       @default(false)
  startedAt     DateTime      @default(now())
  endedAt       DateTime?
  messages      ChatMessage[]
  summary       Summary?
}

model ChatMessage {
  id         String       @id @default(cuid())
  sessionId  String
  session    TrackSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  username   String
  message    String
  isBot      Boolean      @default(false)
  capturedAt DateTime     @default(now())

  @@index([sessionId])
}

model Summary {
  id              String       @id @default(cuid())
  sessionId       String       @unique
  session         TrackSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  bugs            String
  uiUxIssues      String
  featureRequests String
  positives       String
  rawSummary      String
  messageCount    Int
  actionableCount Int
  createdAt       DateTime     @default(now())
}